PORT=5000

# ─── MongoDB (required) ───────────────────────────────────────────────────────
# Local MongoDB Community Server:
MONGODB_URI=mongodb://127.0.0.1:27017/guest_house_db

# MongoDB Atlas (replace with your cluster connection string):
# MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/guest_house_db?retryWrites=true&w=majority

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRE=7d

# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development

# Serve built frontend from backend (production / share mode)
# SERVE_FRONTEND=true

# Seed sample data only when the database has no admin (first run). Set false in production.
AUTO_SEED_ON_EMPTY=true
